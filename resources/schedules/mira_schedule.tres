[gd_resource type="Resource" script_class="ScheduleDefinition" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/resources/schedule_definition.gd" id="1"]
[ext_resource type="Script" path="res://scripts/resources/schedule_entry.gd" id="2"]

[sub_resource type="Resource" id="entry_work"]
