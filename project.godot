; Engine configuration file.
; Godot 4.7 — Stillpoint life-sim RPG foundation + legacy survival prototype.

config_version=5

[application]

config/name="Stillpoint"
config/description="An isekai life-sim RPG foundation with exploration, relationships, and light action."
config/version="0.6.0"
run/main_scene="res://scenes/bootstrap/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/characters/player_up.png"

[autoload]

EventBus="*res://scripts/core/event_bus.gd"
ResourceRegistry="*res://scripts/core/resource_registry_autoload.gd"
InputBindingService="*res://scripts/core/input_binding_service.gd"
WorldTimeService="*res://scripts/time/world_time_service.gd"
RelationshipService="*res://scripts/relationships/relationship_service.gd"
QuestManager="*res://scripts/quests/quest_manager.gd"
GameManager="*res://scripts/core/game_manager.gd"
SceneRouter="*res://scripts/core/scene_router.gd"
SaveService="*res://scripts/core/save_service.gd"
WorldSaveService="*res://scripts/core/world_save_service.gd"
PhysicsSettingsService="*res://scripts/core/physics_settings_service.gd"
AudioManager="*res://scripts/core/audio_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

