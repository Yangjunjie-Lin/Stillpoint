[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"
2d_physics/layer_3="enemy"
2d_physics/layer_4="projectile"
2d_physics/layer_5="pickup"
2d_physics/layer_6="hurtbox"
2d_physics/layer_7="hitbox"
3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="npc"
3d_physics/layer_4="projectile"
3d_physics/layer_5="interactable"
3d_physics/layer_6="hurtbox"
3d_physics/layer_7="hitbox"
3d_physics/layer_8="physics_prop"

[physics]

3d/physics_engine="Jolt Physics"
common/physics_interpolation=true
common/physics_ticks_per_second=60
3d/run_on_separate_thread=false

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
